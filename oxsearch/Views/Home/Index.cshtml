@{
    ViewData["Title"] = "oxsearch";
}

<div class="flex flex-col items-center justify-center min-h-[80vh] px-4">
    <img src="~/images/logo.png" alt="oxsearch" class="mb-8 w-auto h-60" />

    <form action="/search" method="get" class="w-full max-w-2xl">
        <div class="relative">
            <input type="text" name="q" placeholder="Im Web suchen..." autocomplete="off" autofocus
                   class="w-full px-6 py-4 text-lg border border-gray-300 rounded-full shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
            <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-full px-6 py-2 transition">
                Suchen
            </button>
        </div>
    </form>
</div>