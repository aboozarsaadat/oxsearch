@model PaginatedSearchResult
@{
    ViewData["Title"] = ViewBag.Query + " - oxsearch";
    var query = ViewBag.Query as string;
}

<div class="max-w-3xl mx-auto px-4 py-6">
    <form action="/search" method="get" class="mb-8">
        <div class="relative">
            <input type="text" name="q" value="@query"
                   class="w-full px-5 py-3 text-lg border border-gray-300 rounded-full shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
            <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-full px-5 py-1.5 transition">
                Suchen
            </button>
        </div>
    </form>

    @if (Model.Items == null || !Model.Items.Any())
    {
        <p class="text-gray-600 mt-10 text-center">Keine Ergebnisse für "@query" gefunden.</p>
    }
    else
    {
        <p class="text-sm text-gray-500 mb-4">Ungefähr @Model.TotalResults Ergebnisse</p>
        <div class="space-y-6">
            @foreach (var result in Model.Items)
            {
                <div class="bg-white rounded-lg p-4 shadow-sm border border-gray-200">
                    <a href="@Url.Action("RedirectTo", new { id = result.PageId })"
                       class="text-xl text-indigo-600 hover:underline font-semibold">
                        @result.Title
                    </a>
                    <p class="text-green-700 text-sm truncate">@result.Url</p>
                    <p class="text-gray-700 mt-1 leading-relaxed">@result.Snippet</p>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="flex items-center justify-center gap-2 mt-10">
                @if (Model.Page > 1)
                {
                    <a href="@Url.Action("Results", new { q = query, page = Model.Page - 1 })"
                       class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 transition">
                        Zurück
                    </a>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.Page)
                    {
                        <span class="px-4 py-2 bg-indigo-600 text-white rounded-lg">@i</span>
                    }
                    else
                    {
                        <a href="@Url.Action("Results", new { q = query, page = i })"
                           class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 transition">
                            @i
                        </a>
                    }
                }

                @if (Model.Page < Model.TotalPages)
                {
                    <a href="@Url.Action("Results", new { q = query, page = Model.Page + 1 })"
                       class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 transition">
                        Weiter
                    </a>
                }
            </nav>
        }
    }
</div>