@{
    ViewData["Title"] = "Website hinzufügen – oxsearch";
}

<div class="max-w-lg mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">Website zum Index hinzufügen</h2>

    @if (ViewBag.Message != null)
    {
        <div class="bg-green-50 border border-green-300 text-green-800 px-4 py-3 rounded mb-6">
            @ViewBag.Message
        </div>
    }

    <form method="post" action="/submit" class="space-y-5">
        <div>
            <label for="url" class="block text-sm font-medium text-gray-700 mb-1">Website-URL</label>
            <input type="text" name="url" id="url" required placeholder="https://example.com"
                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500" />
        </div>
        <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2.5 rounded-lg transition">
            Website einreichen
        </button>
    </form>
</div>