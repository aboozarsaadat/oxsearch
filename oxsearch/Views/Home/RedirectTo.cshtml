@{
    ViewData["Title"] = "Weiterleitung... – oxsearch";
    var url = ViewBag.TargetUrl as string;
}

<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0; url=@url" />
    <title>Weiterleitung...</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 flex items-center justify-center min-h-screen">
    <div class="text-center">
        <p class="text-gray-700 mb-4">Sie werden zur gewünschten Seite weitergeleitet...</p>
        <p class="text-sm text-gray-500">
            Falls die Weiterleitung nicht funktioniert,
            <a href="@url" class="text-indigo-600 hover:underline">hier klicken</a>
        </p>
    </div>
</body>
</html>